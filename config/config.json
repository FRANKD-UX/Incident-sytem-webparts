{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "shell-header-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/shellHeader/ShellHeaderWebPart.js",
          "manifest": "./src/webparts/shellHeader/ShellHeaderWebPart.manifest.json"
        }
      ]
    },
    "dashboard-summary-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/dashboardSummary/DashboardSummaryWebPart.js",
          "manifest": "./src/webparts/dashboardSummary/DashboardSummaryWebPart.manifest.json"
        }
      ]
    },
    "tickets-grid-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/ticketsGrid/TicketsGridWebPart.js",
          "manifest": "./src/webparts/ticketsGrid/TicketsGridWebPart.manifest.json"
        }
      ]
    },
    "my-board-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/myBoard/MyBoardWebPart.js",
          "manifest": "./src/webparts/myBoard/MyBoardWebPart.manifest.json"
        }
      ]
    },
    "admin-filters-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/adminFilters/AdminFiltersWebPart.js",
          "manifest": "./src/webparts/adminFilters/AdminFiltersWebPart.manifest.json"
        }
      ]
    }
  },
  "externals": {},
  "localizedResources": {
    "ShellHeaderWebPartStrings": "lib/webparts/shellHeader/loc/{locale}.js",
    "DashboardSummaryWebPartStrings": "lib/webparts/dashboardSummary/loc/{locale}.js",
    "TicketsGridWebPartStrings": "lib/webparts/ticketsGrid/loc/{locale}.js",
    "MyBoardWebPartStrings": "lib/webparts/myBoard/loc/{locale}.js",
    "AdminFiltersWebPartStrings": "lib/webparts/adminFilters/loc/{locale}.js"
  }
}
