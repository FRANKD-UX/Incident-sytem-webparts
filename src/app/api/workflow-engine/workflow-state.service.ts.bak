import { Injectable, signal } from '@angular/core';

import { IncidentWorkflowState } from '../../core/contracts/workflow-state.contract';
import { WorkflowActionRequest } from '../../core/contracts/workflow-action.contract';

type DepartmentCode = 'SUP' | 'OPS' | 'ACC';
type IncidentStatus = 'OPEN' | 'IN_PROGRESS' | 'ESCALATED' | 'RESOLVED';

interface IncidentDepartmentRef {
  code: DepartmentCode;
  name: 'Support' | 'Operations' | 'Accounts';
}

interface IncidentRecord {
  id: string;
  title: string;
  description?: string;
  status: IncidentStatus;
  currentDepartment: IncidentDepartmentRef;
  assignedTo?: string;
  priority?: 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL';
  createdAt: string;
  updatedAt: string;
  workflowState: string;
  slaStatus: 'ok' | 'warning' | 'breach';
}

interface TimelineItem {
  at: string;
  type: string;
  message: string;
}

@Injectable({
  providedIn: 'root',
})
export class WorkflowStateService {
  private readonly incidents = signal<IncidentRecord[]>([
    {
      id: 'INC-1001',
      title: 'Customer fibre outage',
      description: 'Customer reports intermittent fibre connectivity.',
      status: 'IN_PROGRESS',
      currentDepartment: { code: 'OPS', name: 'Operations' },
      assignedTo: 'Field Dispatch',
      priority: 'HIGH',
      createdAt: new Date(Date.now() - 1000 * 60 * 120).toISOString(),
      updatedAt: new Date().toISOString(),
      workflowState: 'OPERATIONS_PENDING',
      slaStatus: 'warning',
    },
    {
      id: 'INC-1002',
      title: 'Incorrect debit date',
      description: 'Customer requested billing date change.',
      status: 'OPEN',
      currentDepartment: { code: 'ACC', name: 'Accounts' },
      assignedTo: 'Accounts Queue',
      priority: 'MEDIUM',
      createdAt: new Date(Date.now() - 1000 * 60 * 240).toISOString(),
      updatedAt: new Date().toISOString(),
      workflowState: 'ACCOUNTS_REVIEW',
      slaStatus: 'ok',
    },
    {
      id: 'INC-1003',
      title: 'Planned maintenance notice',
      description: 'Maintenance window needs customer notification.',
      status: 'ESCALATED',
      currentDepartment: { code: 'SUP', name: 'Support' },
      assignedTo: 'Support Queue',
      priority: 'MEDIUM',
      createdAt: new Date(Date.now() - 1000 * 60 * 360).toISOString(),
      updatedAt: new Date().toISOString(),
      workflowState: 'SUPPORT_REVIEW',
      slaStatus: 'ok',
    },
  ]);

  private readonly workflowStates = signal<Record<string, IncidentWorkflowState>>({
    'INC-1001': {
      incidentId: 'INC-1001',
      workflowState: 'OPERATIONS_PENDING',
      currentDepartment: 'Operations',
      allowedActions: [
        'SCHEDULE_TECHNICIAN',
        'RETURN_TO_SUPPORT',
        'COMPLETE_TECHNICAL_WORK',
      ],
      checklistState: [
        { key: 'router-reboot', label: 'Router reboot confirmed', completed: true, required: true },
        { key: 'ont-check', label: 'ONT status checked', completed: true, required: true },
        { key: 'customer-confirmed', label: 'Customer availability confirmed', completed: false, required: true },
      ],
      slaState: {
        status: 'warning',
        dueAt: new Date(Date.now() + 1000 * 60 * 45).toISOString(),
        minutesRemaining: 45,
      },
      ownership: {
        department: 'Operations',
        assignee: 'Field Dispatch',
      },
      timeline: [
        { at: new Date().toISOString(), type: 'ESCALATED', message: 'Escalated from Support to Operations' },
      ],
      escalationState: { active: false },
    },
    'INC-1002': {
      incidentId: 'INC-1002',
      workflowState: 'ACCOUNTS_REVIEW',
      currentDepartment: 'Accounts',
      allowedActions: ['APPROVE_CHANGE', 'REJECT_CHANGE', 'RETURN_TO_SUPPORT'],
      checklistState: [
        { key: 'reference-check', label: 'Reference verified', completed: true, required: true },
        { key: 'payment-check', label: 'Payment status reviewed', completed: false, required: true },
      ],
      slaState: {
        status: 'ok',
        dueAt: new Date(Date.now() + 1000 * 60 * 180).toISOString(),
        minutesRemaining: 180,
      },
      ownership: {
        department: 'Accounts',
        assignee: 'Accounts Queue',
      },
      timeline: [
        { at: new Date().toISOString(), type: 'CREATED', message: 'Assigned to Accounts' },
      ],
      escalationState: { active: false },
    },
    'INC-1003': {
      incidentId: 'INC-1003',
      workflowState: 'SUPPORT_REVIEW',
      currentDepartment: 'Support',
      allowedActions: ['ESCALATE_TO_OPERATIONS', 'ESCALATE_TO_ACCOUNTS', 'CLOSE_INCIDENT'],
      checklistState: [
        { key: 'notice-drafted', label: 'Maintenance notice drafted', completed: true, required: true },
      ],
      slaState: {
        status: 'ok',
        dueAt: new Date(Date.now() + 1000 * 60 * 120).toISOString(),
        minutesRemaining: 120,
      },
      ownership: {
        department: 'Support',
        assignee: 'Support Queue',
      },
      timeline: [
        { at: new Date().toISOString(), type: 'CREATED', message: 'Maintenance notice created' },
      ],
      escalationState: { active: false },
    },
  });

  private readonly auditTrail = signal<Record<string, TimelineItem[]>>({
    'INC-1001': [{ at: new Date().toISOString(), type: 'ESCALATED', message: 'Escalated from Support to Operations' }],
    'INC-1002': [{ at: new Date().toISOString(), type: 'CREATED', message: 'Accounts case opened' }],
    'INC-1003': [{ at: new Date().toISOString(), type: 'CREATED', message: 'Support maintenance notice created' }],
  });

  private readonly attachments = signal<Record<string, unknown[]>>({
    'INC-1001': [],
    'INC-1002': [],
    'INC-1003': [],
  });

  private readonly escalations = signal<Record<string, unknown[]>>({
    'INC-1001': [],
    'INC-1002': [],
    'INC-1003': [],
  });

  getIncidents(): any[] {
    return this.incidents() as any;
  }

  getIncident(id: string): any {
    return (this.incidents().find((incident) => incident.id === id) ?? null) as any;
  }

  createIncident(incident: any): any {
    const id = incident?.id ?? `INC-${Math.floor(1000 + Math.random() * 9000)}`;
    const departmentName = this.normalizeDepartmentName(incident?.currentDepartment?.name ?? incident?.department ?? 'Support');
    const departmentCode = this.departmentNameToCode(departmentName);

    const created: IncidentRecord = {
      id,
      title: incident?.title ?? 'New incident',
      description: incident?.description ?? '',
      status: (incident?.status ?? 'OPEN') as IncidentStatus,
      currentDepartment: {
        code: departmentCode,
        name: departmentName,
      },
      assignedTo: incident?.assignedTo ?? 'Unassigned',
      priority: (incident?.priority ?? 'MEDIUM') as IncidentRecord['priority'],
      createdAt: new Date().toISOString(),
      updatedAt: new Date().toISOString(),
      workflowState: incident?.workflowState ?? 'NEW',
      slaStatus: (incident?.slaStatus ?? 'ok') as IncidentRecord['slaStatus'],
    };

    this.incidents.update((items) => [created, ...items]);
    this.ensureWorkflowState(id, departmentName);

    return created as any;
  }

  getIncidentChain(incidentId: string): any {
    return (this.auditTrail()[incidentId] ?? []) as any;
  }

  getChecklist(incidentId: string): any {
    return (this.workflowStates()[incidentId]?.checklistState ?? []) as any;
  }

  updateChecklistItem(incidentId: string, itemId: string, payload: any = {}): any {
    const current = this.workflowStates()[incidentId];
    if (!current) {
      return [];
    }

    const updatedChecklist = current.checklistState.map((item) =>
      item.key === itemId
        ? {
            ...item,
            completed: payload.completed ?? item.completed,
            required: payload.required ?? item.required,
            label: payload.label ?? item.label,
          }
        : item
    );

    this.workflowStates.update((states) => ({
      ...states,
      [incidentId]: {
        ...current,
        checklistState: updatedChecklist,
      },
    }));

    this.appendAudit(incidentId, 'CHECKLIST_UPDATED', `Checklist item ${itemId} updated`);
    return updatedChecklist as any;
  }

  getAttachments(incidentId: string): any {
    return (this.attachments()[incidentId] ?? []) as any;
  }

  getAuditTrail(incidentId: string): any {
    return (this.auditTrail()[incidentId] ?? []) as any;
  }

  getEscalations(incidentId: string): any {
    return (this.escalations()[incidentId] ?? []) as any;
  }

  getSlaState(incidentId: string): any {
    return (
      this.workflowStates()[incidentId]?.slaState ?? {
        status: 'ok',
      }
    ) as any;
  }

  updateAccountsProcessing(
    incidentId: string,
    payload: { action?: string; actionType?: string; requestedValue?: string; notes?: string; effectiveDate?: string; approved?: boolean } = {}
  ): any {
    return this.applyWorkflowMutation(incidentId, {
      workflowState: payload.approved ? 'ACCOUNTS_APPROVED' : 'ACCOUNTS_REVIEW',
      allowedActions: payload.approved
        ? ['RETURN_TO_SUPPORT']
        : ['APPROVE_CHANGE', 'REJECT_CHANGE', 'RETURN_TO_SUPPORT'],
      currentDepartment: 'Accounts',
      ownership: {
        department: 'Accounts',
        assignee: 'Accounts Queue',
      },
      timelineType: payload.approved ? 'ACCOUNTS_APPROVED' : 'ACCOUNTS_UPDATED',
      timelineMessage: payload.notes ?? 'Accounts processing updated',
    }) as any;
  }

  completeCurrentStep(incidentId: string): any {
    return this.applyWorkflowMutation(incidentId, {
      workflowState: 'STEP_COMPLETED',
      allowedActions: ['RETURN_TO_SUPPORT'],
      timelineType: 'STEP_COMPLETED',
      timelineMessage: 'Current workflow step completed',
    }) as any;
  }

  submitWorkflowAction(request: WorkflowActionRequest): any {
    const action = request.action;

    switch (action) {
      case 'RETURN_TO_SUPPORT':
        return this.applyWorkflowMutation(request.incidentId, {
          workflowState: 'SUPPORT_REVIEW',
          currentDepartment: 'Support',
          allowedActions: ['ESCALATE_TO_OPERATIONS', 'ESCALATE_TO_ACCOUNTS', 'CLOSE_INCIDENT'],
          ownership: {
            department: 'Support',
            assignee: 'Support Queue',
          },
          timelineType: 'RETURNED',
          timelineMessage: 'Returned to Support',
        }) as any;

      case 'COMPLETE_TECHNICAL_WORK':
        return this.applyWorkflowMutation(request.incidentId, {
          workflowState: 'TECHNICAL_WORK_COMPLETED',
          allowedActions: ['RETURN_TO_SUPPORT'],
          timelineType: 'COMPLETED',
          timelineMessage: 'Technical work completed',
        }) as any;

      case 'SCHEDULE_TECHNICIAN':
        return this.applyWorkflowMutation(request.incidentId, {
          workflowState: 'TECHNICIAN_SCHEDULED',
          allowedActions: ['RETURN_TO_SUPPORT', 'COMPLETE_TECHNICAL_WORK'],
          timelineType: 'SCHEDULED',
          timelineMessage: 'Technician scheduled',
        }) as any;

      case 'APPROVE_CHANGE':
        return this.applyWorkflowMutation(request.incidentId, {
          workflowState: 'ACCOUNTS_APPROVED',
          allowedActions: ['RETURN_TO_SUPPORT'],
          timelineType: 'APPROVED',
          timelineMessage: 'Accounts change approved',
        }) as any;

      case 'REJECT_CHANGE':
        return this.applyWorkflowMutation(request.incidentId, {
          workflowState: 'ACCOUNTS_REJECTED',
          allowedActions: ['RETURN_TO_SUPPORT'],
          timelineType: 'REJECTED',
          timelineMessage: 'Accounts change rejected',
        }) as any;

      case 'ESCALATE_TO_OPERATIONS':
        return this.applyWorkflowMutation(request.incidentId, {
          workflowState: 'OPERATIONS_PENDING',
          currentDepartment: 'Operations',
          allowedActions: ['SCHEDULE_TECHNICIAN', 'RETURN_TO_SUPPORT', 'COMPLETE_TECHNICAL_WORK'],
          ownership: {
            department: 'Operations',
            assignee: 'Field Dispatch',
          },
          timelineType: 'ESCALATED',
          timelineMessage: 'Escalated to Operations',
        }) as any;

      case 'ESCALATE_TO_ACCOUNTS':
        return this.applyWorkflowMutation(request.incidentId, {
          workflowState: 'ACCOUNTS_REVIEW',
          currentDepartment: 'Accounts',
          allowedActions: ['APPROVE_CHANGE', 'REJECT_CHANGE', 'RETURN_TO_SUPPORT'],
          ownership: {
            department: 'Accounts',
            assignee: 'Accounts Queue',
          },
          timelineType: 'ESCALATED',
          timelineMessage: 'Escalated to Accounts',
        }) as any;

      case 'CLOSE_INCIDENT':
        return this.applyWorkflowMutation(request.incidentId, {
          workflowState: 'CLOSED',
          allowedActions: [],
          timelineType: 'CLOSED',
          timelineMessage: 'Incident closed',
          status: 'RESOLVED',
        }) as any;

      default:
        return this.workflowStates()[request.incidentId] ?? null;
    }
  }

  private applyWorkflowMutation(
    incidentId: string,
    mutation: {
      workflowState: string;
      allowedActions: string[];
      currentDepartment?: 'Support' | 'Operations' | 'Accounts';
      ownership?: { department: 'Support' | 'Operations' | 'Accounts'; assignee?: string };
      timelineType: string;
      timelineMessage: string;
      status?: IncidentStatus;
    }
  ): any {
    const current = this.workflowStates()[incidentId];
    if (!current) {
      return null;
    }

    const currentDepartment = mutation.currentDepartment ?? current.currentDepartment;
    const updated: IncidentWorkflowState = {
      ...current,
      workflowState: mutation.workflowState,
      currentDepartment,
      allowedActions: mutation.allowedActions,
      ownership: mutation.ownership ?? current.ownership,
      timeline: [
        ...current.timeline,
        {
          at: new Date().toISOString(),
          type: mutation.timelineType,
          message: mutation.timelineMessage,
        },
      ],
    };

    this.workflowStates.update((states) => ({
      ...states,
      [incidentId]: updated,
    }));

    this.incidents.update((items) =>
      items.map((item) =>
        item.id === incidentId
          ? {
              ...item,
              status: mutation.status ?? this.mapWorkflowStateToStatus(mutation.workflowState, item.status),
              currentDepartment: {
                code: this.departmentNameToCode(currentDepartment),
                name: currentDepartment,
              },
              updatedAt: new Date().toISOString(),
              workflowState: mutation.workflowState,
            }
          : item
      )
    );

    this.appendAudit(incidentId, mutation.timelineType, mutation.timelineMessage);
    return updated as any;
  }

  private ensureWorkflowState(
    incidentId: string,
    department: 'Support' | 'Operations' | 'Accounts'
  ): void {
    if (this.workflowStates()[incidentId]) {
      return;
    }

    this.workflowStates.update((states) => ({
      ...states,
      [incidentId]: {
        incidentId,
        workflowState: 'NEW',
        currentDepartment: department,
        allowedActions: [],
        checklistState: [],
        slaState: { status: 'ok' },
        ownership: { department },
        timeline: [],
        escalationState: { active: false },
      },
    }));
  }

  private appendAudit(incidentId: string, type: string, message: string): void {
    this.auditTrail.update((items) => ({
      ...items,
      [incidentId]: [
        ...(items[incidentId] ?? []),
        {
          at: new Date().toISOString(),
          type,
          message,
        },
      ],
    }));
  }

  private normalizeDepartmentName(value: string): 'Support' | 'Operations' | 'Accounts' {
    const normalized = String(value).toLowerCase();
    if (normalized.startsWith('ops')) return 'Operations';
    if (normalized.startsWith('acc')) return 'Accounts';
    return 'Support';
  }

  private departmentNameToCode(value: 'Support' | 'Operations' | 'Accounts'): DepartmentCode {
    switch (value) {
      case 'Operations':
        return 'OPS';
      case 'Accounts':
        return 'ACC';
      default:
        return 'SUP';
    }
  }

  private mapWorkflowStateToStatus(workflowState: string, fallback: IncidentStatus): IncidentStatus {
    if (workflowState === 'CLOSED') {
      return 'RESOLVED';
    }

    if (workflowState.includes('PENDING') || workflowState.includes('REVIEW')) {
      return 'IN_PROGRESS';
    }

    return fallback;
  }
}
